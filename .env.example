# Copy this file to .env.local and use only one environment profile.
# Never commit .env.local or put actual keys in this file.

# Development profile: local PC + development Supabase project
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=
SUPABASE_SECRET_KEY=

# Test profile: public test site + separate test Supabase project
# NEXT_PUBLIC_APP_ENV=test
# NEXT_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-test-publishable-key
# NEXT_PUBLIC_SITE_URL=https://your-test-domain.example
# SUPABASE_SECRET_KEY=your-test-server-secret

# Production profile: production site + separate production Supabase project
# NEXT_PUBLIC_APP_ENV=production
# NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-publishable-key
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.example
# SUPABASE_SECRET_KEY=your-production-server-secret
